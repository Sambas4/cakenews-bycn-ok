{
  "entities": {
    "Article": {
      "title": "Article",
      "description": "A news article or post",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "videoUrl": { "type": "string" },
        "author": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "string" },
        "likes": { "type": "number" },
        "comments": { "type": "number" },
        "isExclusive": { "type": "boolean" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "published"] },
        "scheduledDate": { "type": "string" }
      },
      "required": ["id", "title", "content", "category", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "avatarBg": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] }
      },
      "required": ["uid", "username", "avatarUrl"]
    },
    "Conversation": {
      "title": "Conversation",
      "description": "User direct messages and notifications",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["direct", "notification", "admin"] },
        "ownerId": { "type": "string" },
        "sender": { "type": "string" },
        "lastMessage": { "type": "string" },
        "timestamp": { "type": "string" },
        "unreadCount": { "type": "number" },
        "messages": { "type": "array" }
      },
      "required": ["id", "type", "ownerId", "sender", "lastMessage", "timestamp", "unreadCount", "messages"]
    },
    "Report": {
      "title": "Report",
      "description": "Auditor report / ticket",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "targetId": { "type": "string" },
        "targetType": { "type": "string" },
        "targetTitle": { "type": "string" },
        "targetContentPreview": { "type": "string" },
        "reason": { "type": "string" },
        "description": { "type": "string" },
        "reporter": { "type": "string" },
        "reporterScore": { "type": "number" },
        "status": { "type": "string" },
        "evidenceLinks": { "type": "array" },
        "timestamp": { "type": "string" }
      },
      "required": ["id", "targetId", "targetType", "reason", "reporter", "status"]
    },
    "Campaign": {
      "title": "Broadcast Campaign",
      "description": "Alerts or info over the TV / Ticker",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "priority": { "type": "number" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "name", "message", "type", "priority", "createdAt"]
    }
  },
  "firestore": {
    "/articles/{articleId}": {
      "schema": "Article",
      "description": "Stores news articles"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles"
    },
    "/system/connection-test": {
      "schema": "object",
      "description": "Used to test the connection to Firestore."
    },
    "/conversations/{conversationId}": {
      "schema": "Conversation",
      "description": "Stores user chats and notifications"
    },
    "/reports/{reportId}": {
      "schema": "Report",
      "description": "Stores user moderation reports"
    },
    "/campaigns/{campaignId}": {
      "schema": "Campaign",
      "description": "Stores broadcast configurations"
    }
  }
}
