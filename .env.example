# --- Public client environment (exposed to browser) ---
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: comma-separated UIDs that bootstrap as super-admin during
# the very first deployment. After that, role management lives in DB only.
# IMPORTANT: clear this variable after the first production deployment
# (j+1) and rebuild — the value is baked into the bundle at build time
# and remains a credential equivalent until then.
VITE_BOOTSTRAP_SUPER_ADMIN_UIDS=

# Web Push (VAPID) public key. Required for the in-app push subscription
# flow to register the device with Supabase. Generate with
# `npx web-push generate-vapid-keys` and store the *private* key as a
# Supabase secret (see supabase/README.md). Leave empty to disable push.
VITE_VAPID_PUBLIC_KEY=

# Optional: Sentry DSN for error monitoring. The Sentry SDK is loaded
# lazily from a CDN only when a DSN is set AND the viewer has accepted
# analytics tracking. Leave empty to ship the bundle without Sentry.
# You can also set this at runtime by writing `window.__cakeSentryDsn`
# from a deployment-config endpoint.
VITE_SENTRY_DSN=

# --- Edge Function secrets (server-side only — never exposed to the browser) ---
# These are NOT consumed by Vite. Set them via:
#     supabase secrets set KEY=value
# Then redeploy each Edge Function.

# Comma-separated list of allowed CORS origins for the privileged
# Edge Functions (delete-account, export-user-data, healthcheck,
# send-push). MUST be set in production — when unset, the helper
# falls back to '*' with a logged warning, which is acceptable for
# local `supabase functions serve` only.
# Example: https://cakenews.app,https://staging.cakenews.app
# ALLOWED_ORIGINS=

# Supabase service-role key (bypasses RLS). Used by every Edge Function.
# Rotate every 180 days. NEVER commit the real value.
# SUPABASE_SERVICE_ROLE_KEY=

# Web Push private key counterpart to VITE_VAPID_PUBLIC_KEY.
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:ops@cakenews.app

# APNs (iOS native push)
# APNS_TEAM_ID=
# APNS_KEY_ID=
# APNS_PRIVATE_KEY=
# APNS_BUNDLE_ID=app.cakenews.app
# APNS_USE_SANDBOX=

# FCM (Android native push) — service-account JSON as a single line.
# FCM_PROJECT_ID=
# FCM_SERVICE_ACCOUNT=
